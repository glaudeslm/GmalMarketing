# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Gmail Configuration
GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=your_16_digit_app_password_here

# Application Settings
SEND_TIME=09:00
DEFAULT_SEND_DELAY_MIN=45
DEFAULT_SEND_DELAY_MAX=150

# Email Configuration
EMAIL_SUBJECT_TEMPLATE=Hello {FirstName}! {subject}
OFFICIAL_SITE_LINK=https://example.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log
